# ===========================================
# SECURITY CONFIGURATION
# ===========================================

# Security Features
SECURITY_ENABLED=true
SECURITY_HEADERS_ENABLED=true
SECURITY_CSP_ENABLED=true
SECURITY_HSTS_ENABLED=true

# ===========================================
# RATE LIMITING CONFIGURATION
# ===========================================

# Rate Limiting
RATE_LIMITING_ENABLED=true
API_RATE_LIMIT=60
AUTH_RATE_LIMIT=5
LOGIN_RATE_LIMIT=3

# ===========================================
# AUDIT TRAIL CONFIGURATION
# ===========================================

# Audit Trail
AUDIT_TRAIL_ENABLED=true
AUDIT_LOG_CHANNEL=audit
AUDIT_LOG_LEVEL=info
AUDIT_RETENTION_DAYS=90
AUDIT_LOG_QUERIES=false

# ===========================================
# CORS CONFIGURATION
# ===========================================

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:4000,http://localhost:3000,http://127.0.0.1:4000,http://127.0.0.1:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOWED_HEADERS=Accept,Authorization,Content-Type,X-Requested-With,X-CSRF-TOKEN
CORS_MAX_AGE=86400

# ===========================================
# PASSWORD POLICY CONFIGURATION
# ===========================================

# Password Requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SYMBOLS=true
PASSWORD_MAX_AGE_DAYS=90

# ===========================================
# SESSION SECURITY CONFIGURATION
# ===========================================

# Session Security
SESSION_LIFETIME=120
SESSION_SECURE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# ===========================================
# INPUT VALIDATION CONFIGURATION
# ===========================================

# Input Validation
MAX_STRING_LENGTH=255
MAX_FILE_SIZE=10240
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx
SANITIZE_INPUT=true

# ===========================================
# ENCRYPTION CONFIGURATION
# ===========================================

# Encryption
ENCRYPTION_KEY_ROTATION_DAYS=365
ENCRYPTION_ALGORITHM=AES-256-CBC

# ===========================================
# CSRF CONFIGURATION
# ===========================================

# CSRF Protection
CSRF_ENABLED=true
CSRF_TOKEN_LIFETIME=120

# ===========================================
# XSS PROTECTION CONFIGURATION
# ===========================================

# XSS Protection
